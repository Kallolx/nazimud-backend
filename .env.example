# Server
PORT=4000
NODE_ENV=development
# Comma-separated list supported. Wildcards like https://*.vercel.app are supported.
CLIENT_ORIGIN=http://localhost:3000,https://nazimud.vercel.app,https://www.nazimud.vercel.app
PUBLIC_BASE_URL=http://localhost:4000

IMAGE_STORAGE=cloudinary
LOCAL_UPLOAD_DIR=uploads

# PostgreSQL
DATABASE_URL="postgresql://postgres:your_password@localhost:5432/backpageseek?schema=public"

# Auth
JWT_SECRET=change_this_to_a_long_random_secret
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_DAYS=30
# Captcha mode: use turnstile in production, mock for local one-click flow.
CAPTCHA_MODE=mock
LOCAL_CAPTCHA_TOKEN=local-dev-human
TURNSTILE_SECRET_KEY=
TURNSTILE_VERIFY_URL=https://challenges.cloudflare.com/turnstile/v0/siteverify
ALLOWED_EMAIL_DOMAINS=gmail.com,yahoo.com,outlook.com,hotmail.com,icloud.com,proton.me,protonmail.com,live.com,aol.com,mail.com

# Cloudinary
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
CLOUDINARY_FOLDER=backpageseek/posts
